# Novox Blog Admin Dashboard Configuration
PORT=3000

# Security Gate Passcode (Disabled by default, but configurable)
ADMIN_PASSCODE=your_passcode_here

# Google Gemini API Key
GEMINI_API_KEY=your_google_gemini_api_key_here

# GitHub Repository Configurations
GITHUB_OWNER=your_github_username_or_org_here
GITHUB_REPO=your_repository_name_here
GITHUB_BRANCH=main
GITHUB_TOKEN=your_github_personal_access_token_here
